rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check role
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    // Helper function to check if user is active
    function isActive() {
      return isAuthenticated() && getUserData().active == true;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own data
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Managers and admins can read all users
      allow read: if hasRole('manager') || hasRole('admin');
      
      // Admins can create any user profile. Users may only create *their own* profile as an employee.
      // This prevents a newly-created Auth user from self-assigning elevated roles like admin/manager.
      allow create: if hasRole('admin') || (
        isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.data.uid == userId &&
        request.resource.data.active == true &&
        request.resource.data.role == 'employee'
      );
      
      // Only admins can update/delete user data
      allow update, delete: if hasRole('admin');
    }
    
    // Time entries collection
    match /timeEntries/{entryId} {
      // Users can get individual entries (even non-existent ones) or list their own entries
      allow get: if isAuthenticated() && 
                    (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Managers can read entries from all users
      allow read: if hasRole('manager') || hasRole('admin');
      
      // Users can create/update their own entries
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       isActive();
      
      allow update: if isAuthenticated() && 
                       (request.auth.uid == resource.data.userId || hasRole('admin')) &&
                       isActive();
      
      // Only admins can delete entries
      allow delete: if hasRole('admin');
    }
    
    // Correction Requests collection
    match /correctionRequests/{requestId} {
      // Employees can create their own requests
      allow create: if isAuthenticated() && 
                       request.resource.data.employee_id == request.auth.uid &&
                       isActive();
      
      // Employees can read their own requests
      allow list: if isAuthenticated() && 
                     resource.data.employee_id == request.auth.uid;
      allow get: if isAuthenticated() && 
                    (resource == null || resource.data.employee_id == request.auth.uid);
      
      // Managers and admins can read all requests
      allow read: if hasRole('manager') || hasRole('admin');
      
      // Only admins can update requests (status changes)
      allow update: if hasRole('admin');
    }
    
    // System Settings collection
    match /systemSettings/{document} {
      // Admins can read and write all system settings
      allow read, write: if hasRole('admin');
      
      // All authenticated users can read payroll settings to respect lock dates
      allow read: if isAuthenticated() && document == 'payroll';
    }
  }
}

